{
  "name": "the-resolution",
  "version": "0.1.0",
  "private": true,
  "description": "The Resolution — a music theory study app. A tip of the hat to music's tension and resolve.",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm run prisma:migrate --workspace server",
    "db:seed": "npm run prisma:seed --workspace server",
    "db:studio": "npm run prisma:studio --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
